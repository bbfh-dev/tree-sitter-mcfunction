{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "mcfunction",
  "word": "identifier",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_statement"
      }
    },
    "_statement": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "_indentation"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "comment"
                }
              ]
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "_newline"
        }
      ]
    },
    "backslash": {
      "type": "PATTERN",
      "value": "\\s*\\\\\\s*"
    },
    "_indentation": {
      "type": "PATTERN",
      "value": "[ \\t]+"
    },
    "_space": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PATTERN",
          "value": " +"
        },
        {
          "type": "SYMBOL",
          "name": "backslash"
        }
      ]
    },
    "_newline": {
      "type": "PATTERN",
      "value": "\\r?\\n"
    },
    "identifier": {
      "type": "PATTERN",
      "value": "[_A-Za-z0-9]+"
    },
    "line": {
      "type": "PATTERN",
      "value": "[^\\r\\n]*"
    },
    "scoreboard_operation": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "="
          },
          {
            "type": "STRING",
            "value": "+="
          },
          {
            "type": "STRING",
            "value": "-="
          },
          {
            "type": "STRING",
            "value": "*="
          },
          {
            "type": "STRING",
            "value": "/="
          },
          {
            "type": "STRING",
            "value": "%="
          },
          {
            "type": "STRING",
            "value": "><"
          },
          {
            "type": "STRING",
            "value": "<"
          },
          {
            "type": "STRING",
            "value": ">"
          }
        ]
      }
    },
    "boolean": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "true"
          },
          {
            "type": "STRING",
            "value": "false"
          }
        ]
      }
    },
    "comment": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "#~>"
                },
                {
                  "type": "SYMBOL",
                  "name": "identifier"
                }
              ]
            },
            {
              "type": "SEQ",
              "members": [
                {
                  "type": "STRING",
                  "value": "#:"
                },
                {
                  "type": "SYMBOL",
                  "name": "identifier"
                }
              ]
            },
            {
              "type": "STRING",
              "value": "#>"
            },
            {
              "type": "STRING",
              "value": "#"
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "line"
        }
      ]
    }
  },
  "extras": [],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}